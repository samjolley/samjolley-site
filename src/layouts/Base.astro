---
import '../styles/global.css';

interface Props {
  title: string;
  description: string;
  ogType?: string;
  structuredData?: object;
}

const { title, description, ogType = 'website', structuredData } = Astro.props;
const canonical = new URL(Astro.url.pathname, Astro.site);
const ogImage = new URL('/og.png', Astro.site);
const navItems = [
  { href: '/', label: 'Home' },
  { href: '/work/', label: 'Work' },
  { href: '/writing/', label: 'Writing' },
  { href: '/about/', label: 'About' },
];
const currentPath = Astro.url.pathname.replace(/\/?$/, '/');

const personSchema = {
  '@context': 'https://schema.org',
  '@type': 'Person',
  name: 'Sam Jolley',
  url: 'https://samjolley.com',
  jobTitle: 'IT operations and automation engineer',
  worksFor: {
    '@type': 'Organization',
    name: 'ZeroBeatLabs',
    url: 'https://zerobeatlabs.org',
  },
  // sameAs: list only live profiles. Add each as it is claimed.
  sameAs: ['https://github.com/samjolley', 'https://www.linkedin.com/in/samjolley'],
};
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonical} />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="apple-touch-icon" href="/apple-touch-icon.png" />
    <link rel="manifest" href="/site.webmanifest" />
    <meta name="theme-color" content="#14605f" />
    <link rel="sitemap" href="/sitemap-index.xml" />
    <link
      rel="alternate"
      type="application/rss+xml"
      title="Sam Jolley Writing"
      href="/rss.xml"
    />
    <meta property="og:type" content={ogType} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonical} />
    <meta property="og:site_name" content="Sam Jolley" />
    <meta property="og:image" content={ogImage} />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta property="og:image:alt" content={title} />
    <meta name="twitter:card" content="summary_large_image" />
    <script type="application/ld+json" set:html={JSON.stringify(personSchema)} />
    {structuredData && <script type="application/ld+json" set:html={JSON.stringify(structuredData)} />}
  </head>
  <body>
    <a class="skip-link" href="#main">Skip to content</a>
    <header class="site-header">
      <div class="wrap">
        <a class="site-name" href="/">Sam Jolley</a>
        <nav class="site-nav" aria-label="Main navigation">
          <ul>
            {
              navItems.map((item) => (
                <li>
                  <a
                    href={item.href}
                    aria-current={currentPath === item.href ? 'page' : undefined}
                  >
                    {item.label}
                  </a>
                </li>
              ))
            }
          </ul>
        </nav>
      </div>
    </header>
    <main id="main" class="wrap">
      <slot />
    </main>
    <footer class="site-footer">
      <div class="wrap">
        <p>&copy; {new Date().getFullYear()} Sam Jolley</p>
        <p>
          <a href="mailto:hello@zerobeatlabs.org">hello@zerobeatlabs.org</a>
          &middot; <a href="/privacy/">Privacy</a>
        </p>
      </div>
    </footer>
  </body>
</html>

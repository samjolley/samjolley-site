---
import Base from '../layouts/Base.astro';
import { getCollection, render } from 'astro:content';

const work = (await getCollection('work')).sort(
  (a, b) => a.data.order - b.data.order,
);
const workEntries = await Promise.all(
  work.map(async (item) => ({
    item,
    Content: (await render(item)).Content,
  })),
);
---

<Base
  title="Work | Sam Jolley"
  description="Selected projects across IT operations reporting, custom keyboard hardware, operational security, RC and drone systems, and self-hosted infrastructure."
>
  <h1>Work</h1>
  <p class="lede">
    Selected public-safe work across IT operations, automation, infrastructure,
    and hands-on engineering.
  </p>
  <div class="work-list">
    {
      workEntries.map(({ item, Content }) => (
        <article class="work-item">
          <h2>{item.data.title}</h2>
          {item.data.synthetic && <p class="badge">Sample demonstration</p>}
          <p class="summary">{item.data.summary}</p>
          <div class="work-body">
            <Content />
          </div>
        </article>
      ))
    }
  </div>
</Base>

<style>
  .work-list {
    display: grid;
    gap: var(--space-4);
    margin-top: var(--space-4);
  }

  .work-item {
    border-top: 1px solid var(--color-border);
    padding-top: var(--space-4);
  }

  .work-item:first-child {
    border-top: 0;
    padding-top: 0;
  }

  .work-item h2 {
    margin-top: 0;
  }

  .summary {
    color: var(--color-ink-muted);
    font-size: var(--text-lg);
  }

  .work-body :global(ul),
  .work-body :global(ol) {
    max-width: var(--measure);
    padding-left: var(--space-3);
  }

  .work-body :global(li) {
    margin-bottom: var(--space-1);
  }
</style>

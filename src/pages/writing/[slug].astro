---
import Base from '../../layouts/Base.astro';
import { getCollection, render } from 'astro:content';

export async function getStaticPaths() {
  // Drafts render in `dev` for review but are excluded from production builds,
  // so they never reach the sitemap or RSS feed.
  const posts = await getCollection('writing', ({ data }) =>
    import.meta.env.PROD ? !data.draft : true,
  );
  return posts.map((post) => ({ params: { slug: post.id }, props: { post } }));
}

const { post } = Astro.props;
const { Content } = await render(post);

const canonical = new URL(Astro.url.pathname, Astro.site);

const structuredData = {
  '@context': 'https://schema.org',
  '@type': 'BlogPosting',
  headline: post.data.title,
  description: post.data.description,
  datePublished: post.data.pubDate.toISOString(),
  author: { '@type': 'Person', name: 'Sam Jolley', url: 'https://samjolley.com' },
  mainEntityOfPage: canonical.href,
  ...(post.data.keywords.length > 0 && { keywords: post.data.keywords.join(', ') }),
};

const fmtDate = (d: Date) =>
  d.toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric' });
---

<Base
  title={`${post.data.title} | Sam Jolley`}
  description={post.data.description}
  ogType="article"
  structuredData={structuredData}
>
  <article class="article">
    <p class="post-meta">
      <time datetime={post.data.pubDate.toISOString()}>
        {fmtDate(post.data.pubDate)}
      </time>
      {post.data.draft && <span class="draft-badge">Draft</span>}
    </p>
    <h1>{post.data.title}</h1>
    <div class="article-body">
      <Content />
    </div>
    <p class="back"><a href="/writing/">&larr; All writing</a></p>
  </article>
</Base>

<style>
  .article {
    max-width: var(--measure);
  }

  .post-meta {
    display: flex;
    align-items: center;
    gap: var(--space-2);
    margin: 0 0 var(--space-1);
    color: var(--color-ink-muted);
    font-size: 0.9rem;
  }

  .draft-badge {
    font-family: var(--font-mono);
    font-size: 0.8rem;
    border: 1px solid var(--color-border);
    border-radius: var(--radius);
    padding: 0.1em 0.55em;
    background: var(--color-surface);
    color: var(--color-ink-muted);
  }

  .article-body :global(h2) {
    margin-top: var(--space-4);
  }

  .article-body :global(ul),
  .article-body :global(ol) {
    padding-left: var(--space-3);
  }

  .article-body :global(li) {
    margin-bottom: var(--space-1);
  }

  .back {
    margin-top: var(--space-5);
    border-top: 1px solid var(--color-border);
    padding-top: var(--space-3);
  }
</style>

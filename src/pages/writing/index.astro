---
import Base from '../../layouts/Base.astro';
import { getCollection } from 'astro:content';

const posts = (await getCollection('writing')).sort(
  (a, b) => b.data.pubDate.getTime() - a.data.pubDate.getTime(),
);

const fmtDate = (d: Date) =>
  d.toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric' });
---

<Base
  title="Writing — Sam Jolley"
  description="Notes on IT operations, automation, and keeping human judgment in consequential decisions."
>
  <h1>Writing</h1>
  <p class="lede">
    Notes on IT operations, automation, and keeping human judgment in
    consequential decisions.
  </p>

  {posts.length === 0 && <p>Nothing published yet.</p>}

  <ul class="post-list">
    {
      posts.map((post) => (
        <li>
          <p class="post-meta">
            <time datetime={post.data.pubDate.toISOString()}>
              {fmtDate(post.data.pubDate)}
            </time>
            {post.data.draft && <span class="badge">Draft</span>}
          </p>
          <h2>
            <a href={`/writing/${post.id}/`}>{post.data.title}</a>
          </h2>
          <p class="summary">{post.data.description}</p>
        </li>
      ))
    }
  </ul>
</Base>

<style>
  .post-list {
    list-style: none;
    margin: var(--space-4) 0 0;
    padding: 0;
    display: grid;
    gap: var(--space-4);
  }

  .post-list li {
    border-top: 1px solid var(--color-border);
    padding-top: var(--space-4);
  }

  .post-list li:first-child {
    border-top: 0;
    padding-top: 0;
  }

  .post-list h2 {
    margin: 0 0 var(--space-1);
  }

  .post-list h2 a {
    text-decoration: none;
    color: var(--color-ink);
  }

  .post-list h2 a:hover {
    color: var(--color-accent-strong);
    text-decoration: underline;
    text-underline-offset: 0.2em;
  }

  .post-meta {
    display: flex;
    align-items: center;
    gap: var(--space-2);
    margin: 0 0 var(--space-1);
    color: var(--color-ink-muted);
    font-size: 0.9rem;
  }

  .summary {
    color: var(--color-ink-muted);
    margin-bottom: 0;
  }
</style>

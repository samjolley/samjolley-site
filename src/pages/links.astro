---
import LinkHub from '../layouts/LinkHub.astro';
import { personalLinkGroups } from '../data/link-hub';

const title = 'Links | Sam Jolley';
const description = 'Projects, writing, technical resources, and professional profiles from Sam Jolley.';
const profileSchema = {
  '@context': 'https://schema.org',
  '@type': 'ProfilePage',
  name: title,
  url: 'https://samjolley.com/links/',
  mainEntity: {
    '@type': 'Person',
    name: 'Sam Jolley',
    url: 'https://samjolley.com',
    image: 'https://samjolley.com/sam-jolley-headshot.webp',
    jobTitle: 'IT operations and automation engineer',
    worksFor: { '@type': 'Organization', name: 'ZeroBeatLabs', url: 'https://zerobeatlabs.org' },
    sameAs: ['https://github.com/samjolley', 'https://www.linkedin.com/in/samjolley'],
  },
};
---

<LinkHub title={title} description={description} structuredData={profileSchema}>
  <div class="link-hub">
    <header class="profile-header">
      <img class="headshot" src="/sam-jolley-headshot.webp" width="512" height="512" alt="" decoding="async" />
      <p class="eyebrow">Engineer · operator · builder</p>
      <h1>Sam Jolley</h1>
      <p class="lede">IT operations, automation, and hands-on engineering.</p>
    </header>

    {
      personalLinkGroups.map((group, groupIndex) => (
        <section class="link-section" aria-labelledby={`group-${groupIndex}`}>
          <div class="section-heading">
            <h2 id={`group-${groupIndex}`}>{group.heading}</h2>
            {group.description && <p>{group.description}</p>}
          </div>
          <ul class:list={['link-list', { compact: groupIndex === 1 }]}>
            {group.links.map((link) => (
              <li>
                <a class:list={['link-card', { featured: link.featured }]} href={link.href}>
                  <span class="link-label">{link.label}</span>
                  {link.description && <span class="link-description">{link.description}</span>}
                  {groupIndex === 2 && <span class="link-source">External resource</span>}
                </a>
              </li>
            ))}
          </ul>
        </section>
      ))
    }
  </div>
</LinkHub>

<style>
  :global(body) {
    background: radial-gradient(circle at top, rgba(20, 96, 95, 0.11), transparent 30rem), #f8faf9;
  }

  :global(main) { padding: 0; }

  .link-hub {
    width: calc(100% - 2rem);
    max-width: 42rem;
    margin: 0 auto;
    padding: 3rem 0 4.5rem;
  }

  .profile-header { text-align: center; margin-bottom: 2.5rem; }

  .headshot {
    display: block;
    width: 8rem;
    height: 8rem;
    margin: 0 auto 1.25rem;
    object-fit: cover;
    border-radius: 50%;
    border: 4px solid #fff;
    box-shadow: 0 12px 32px rgba(31, 36, 40, 0.18);
  }

  .eyebrow {
    margin: 0 0 0.5rem;
    color: var(--color-accent-strong);
    font-family: var(--font-mono);
    font-size: 0.78rem;
    font-weight: 700;
    letter-spacing: 0.08em;
    text-transform: uppercase;
  }

  h1 { margin-bottom: 0.4rem; }
  .lede { margin: 0 auto; max-width: 32rem; }
  .link-section + .link-section { margin-top: 2.75rem; }
  .section-heading { margin-bottom: 1rem; }
  .section-heading h2 { margin: 0 0 0.35rem; font-size: 1.18rem; }
  .section-heading p { margin: 0; color: var(--color-ink-muted); font-size: 0.96rem; }

  .link-list {
    display: grid;
    gap: 0.8rem;
    margin: 0;
    padding: 0;
    list-style: none;
  }

  .link-list.compact { grid-template-columns: repeat(2, minmax(0, 1fr)); }

  .link-card {
    display: flex;
    min-width: 0;
    min-height: 3.5rem;
    flex-direction: column;
    justify-content: center;
    padding: 0.95rem 1.1rem;
    border: 1px solid var(--color-border);
    border-radius: 12px;
    background: rgba(255, 255, 255, 0.92);
    box-shadow: 0 3px 12px rgba(31, 36, 40, 0.06);
    color: var(--color-ink);
    text-decoration: none;
    overflow-wrap: anywhere;
    transition: border-color 150ms ease, box-shadow 150ms ease, transform 150ms ease;
  }

  .link-card:hover {
    border-color: var(--color-accent);
    box-shadow: 0 8px 20px rgba(20, 96, 95, 0.12);
    color: var(--color-ink);
    transform: translateY(-1px);
  }

  .link-card.featured { border-color: var(--color-accent); background: var(--color-accent); color: #fff; }
  .link-card.featured:hover { background: var(--color-accent-strong); color: #fff; }
  .link-label { font-weight: 700; line-height: 1.25; }
  .link-description { margin-top: 0.28rem; color: var(--color-ink-muted); font-size: 0.9rem; line-height: 1.45; }
  .featured .link-description { color: rgba(255, 255, 255, 0.84); }

  .link-source {
    margin-top: 0.45rem;
    color: var(--color-accent-strong);
    font-family: var(--font-mono);
    font-size: 0.72rem;
    font-weight: 700;
    letter-spacing: 0.04em;
    text-transform: uppercase;
  }

  @media (max-width: 32rem) {
    .link-hub { width: calc(100% - 1.25rem); padding-top: 2rem; }
    .link-list.compact { grid-template-columns: 1fr; }
  }

  @media (prefers-reduced-motion: reduce) {
    .link-card { transition: none; }
    .link-card:hover { transform: none; }
  }
</style>
